# StreamPulse — Environment variables (copy to .env and fill in values)
# 12-Factor App: never hardcode secrets in source code.
# .env is gitignored — only .env.example is committed.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development   # development | production

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=require
SUPABASE_DB_URL=postgres://postgres:password@localhost:5432/streampulse

# ── Auth JWT RS256 ────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 4096
#                openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=./secrets/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/public.pem

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=streampulse-api

# ── Security ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
